# football-data.org API token（必填）
# 注册：https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your_token_here

# Discord webhook URL（必填，scheduler 用它推消息）
# 频道 -> 编辑频道 -> 集成 -> Webhooks -> 新建 -> 复制 URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# 时区，影响早报/周报/开赛提醒的推送时间
TZ=Europe/Berlin

# SQLite 文件位置（容器里固定 /app/data/football-radar.db；本地默认 ./data/）
# FOOTBALL_RADAR_DB=./data/football-radar.db
