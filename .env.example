# football-data.org API token（必填）
# 注册：https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your_token_here

# Discord webhook URL（必填，scheduler 用它推联赛 / 欧冠消息）
# 频道 -> 编辑频道 -> 集成 -> Webhooks -> 新建 -> 复制 URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# Discord webhook URL — 世界杯专用频道（可选，不设则世界杯也走 DISCORD_WEBHOOK_URL）
DISCORD_WEBHOOK_URL_WC=https://discord.com/api/webhooks/aaaa/bbbb

# Discord webhook URL — 欧洲杯专用频道（可选，不设则欧洲杯也走 DISCORD_WEBHOOK_URL）
# 下届 Euro 2028 才会真正有数据，先把 webhook 配好待用
DISCORD_WEBHOOK_URL_EC=https://discord.com/api/webhooks/cccc/dddd

# Discord webhook URL — 南美解放者杯专用频道（可选，不设则解放者杯也走 DISCORD_WEBHOOK_URL）
# 比赛多在欧洲深夜（凌晨 0–4 点），强烈建议在 Discord 把这个频道单独「静音」
DISCORD_WEBHOOK_URL_CLI=https://discord.com/api/webhooks/eeee/ffff

# 时区，影响日期窗口与展示时间
TZ=Europe/Amsterdam

# SQLite 文件位置（默认 ./data/football-radar.db）
# FOOTBALL_RADAR_DB=./data/football-radar.db
